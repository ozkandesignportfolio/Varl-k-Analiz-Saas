[
  {
    "id": "TC001",
    "title": "Login with valid credentials redirects to Dashboard",
    "description": "Verifies that an existing user can sign in with email/password and is redirected to the protected dashboard.",
    "category": "Authentication",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/login\""
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Dashboard\" is visible"
      }
    ]
  },
  {
    "id": "TC002",
    "title": "Login with invalid credentials shows authentication error",
    "description": "Verifies that wrong email/password prevents login and shows a visible authentication error message.",
    "category": "Authentication",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/login\""
      },
      {
        "type": "action",
        "description": "Type \"$TEST_ALT_LOGIN_EMAIL\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"Wrong$TEST_LOGIN_PASSWORD!\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Invalid\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/login\""
      }
    ]
  },
