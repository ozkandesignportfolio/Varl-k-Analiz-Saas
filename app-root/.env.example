NEXT_PUBLIC_SUPABASE_URL=your_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_here
# Next.js only loads .env.local from the project root (app-root/.env.local).
# Localhost requests can use Cloudflare's test widget automatically.
# Production requires real Turnstile keys in both vars below.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here
ADMIN_DASHBOARD_SECRET=optional_admin_dashboard_secret_for_machine_access
STRIPE_SECRET_KEY=sk_test_xxx
# Optional for local/dev only when intentionally using live Stripe keys.
STRIPE_ALLOW_LIVE_IN_NON_PROD=false
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PREMIUM=price_xxx
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Automation notifications
# These values are required anywhere the notification worker or dispatch route runs.
AUTOMATION_CRON_SECRET=change_me
# Vercel Cron signs scheduled requests with CRON_SECRET.
# Keep this identical to AUTOMATION_CRON_SECRET in Vercel production.
CRON_SECRET=change_me
SEND_EMAIL_HOOK_SECRET=v1,whsec_your_base64_secret_here
RESEND_API_KEY=re_xxx
AUTOMATION_FROM_EMAIL=no-reply@your-domain.com
# Optional reply-to for operational follow-ups.
AUTOMATION_REPLY_TO_EMAIL=support@your-domain.com

# Email Reminder System (for unverified users)
# Secret for cron job authentication (Vercel Cron or Supabase Edge Function)
EMAIL_REMINDER_CRON_SECRET=change_me_email_reminder

OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Sentry (error monitoring)
# Keep disabled in local development by default.
# In production, app logs a one-time warning if DSN is empty, enable flags are invalid, or Sentry resolves disabled.
SENTRY_ENABLED=false
NEXT_PUBLIC_SENTRY_ENABLED=false

# DSN: use NEXT_PUBLIC_SENTRY_DSN for browser + server, optional SENTRY_DSN for server override.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Environment and release metadata (optional but recommended).
SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=

# Performance sampling (0.0 - 1.0).
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Optional: required only for source map upload during build.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
